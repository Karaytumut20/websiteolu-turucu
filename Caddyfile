{
  # Ask this endpoint to check if the incoming domain should be issued a certificate
  on_demand_tls {
    ask http://nextjs:3000/api/check-domain
    interval 2m
    burst 5
  }
}

# Catch-all for HTTP -> HTTPS redirect
:80 {
  route {
    redir https://{host}{uri}
  }
}

# Main Application & On-Demand Custom Domains
https:// {
  tls {
    on_demand
  }

  reverse_proxy nextjs:3000
}
